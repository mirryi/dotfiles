// WARNING: Do not edit this file.
// It was generated by processing a template.

$bg: {{ colors.background }};
$fg: {{ colors.foreground }};
$muted: {{ colors.black }};
$accent: {{ colors.blue }};
$urgent: {{ colors.red }};
$yellow: {{ colors.yellow }};
$orange: {{ colors.darkyellow }};
$green: {{ colors.green }};
$widget: {{ colors.widget }};

* {
  all: unset;
  font-family: "{{ font }}";
  font-size: 12px;
}

window {
  background-color: $bg;
}
.bar {
  padding: 3px 8px;
}

.mod {
  background-color: $widget;
  color: $fg;
  border: 1px solid darken($widget, 9%);
  border-radius: 4px;
  padding: 0px 13px;
}

// Mono Nerd Font variant: one centred cell per glyph at normal weight.
.icn {
  font-family: "JetBrainsMono Nerd Font Mono";
  font-size: 15px;
}
.icn-sm {
  font-size: 13px;
}

.rev {
  padding-left: 10px;
}
.rev-date {
  padding-right: 7px;
}
.pctsign {
  padding-left: 2px;
}
.btime {
  padding-left: 6px;
}

.battery.chg {
  color: $accent;
}
.battery.green {
  color: $green;
}
.battery.yellow {
  color: $yellow;
}
.battery.orange {
  color: $orange;
}
.battery.red {
  color: $urgent;
}

.mullvad.on {
  color: $green;
}
.mullvad.mid {
  color: $yellow;
}
.mullvad.off {
  color: $urgent;
}

.i3 {
  padding: 1px;
}
.ws {
  padding: 1px 7px;
  color: $muted;
  border: 1px solid transparent;
  border-radius: 3px;
  transition: color 150ms, border-color 150ms;
}
.ws.focused {
  color: $accent;
  border-color: $accent;
}
.ws.urgent {
  color: $urgent;
  border-color: $urgent;
}
.ws:hover {
  color: $fg;
}
