// WARNING: Do not edit this file.
// It was generated by processing a template.

$bg: {{ colors.background }};
$fg: {{ colors.foreground }};
$muted: {{ colors.black }};
$accent: {{ colors.blue }};
$urgent: {{ colors.red }};
$yellow: {{ colors.yellow }};
$orange: {{ colors.darkyellow }};
$green: {{ colors.green }};
$widget: {{ colors.widget }};
$hover: {{ colors.hover }};

* {
  all: unset;
  font-family: "{{ font }}";
  font-size: 12px;
}

window {
  background-color: $bg;
}
.bar {
  padding: 5px 8px;
}

.mod {
  background-color: $widget;
  color: $fg;
  border: 1px solid darken($widget, 9%);
  border-radius: 4px;
  padding: 0px 13px;
}

// Mono Nerd Font variant: one centred cell per glyph at normal weight.
.icn {
  font-family: "JetBrainsMono Nerd Font Mono";
  font-size: 17px;
  // Glyphs sit in a tall em-box; pull the empty space back so the bar can be
  // short without shrinking the glyph.
  margin: -5px 0px;
}
.icn-sm {
  font-size: 13px;
}

.rev {
  padding-left: 10px;
}
.rev-left {
  padding-right: 10px;
}
.rev-date {
  padding-right: 7px;
}
.pctsign {
  padding-left: 2px;
}
.btime {
  padding-left: 6px;
}

.battery.chg {
  color: $accent;
}
.battery.green {
  color: $green;
}
.battery.yellow {
  color: $yellow;
}
.battery.orange {
  color: $orange;
}
.battery.red {
  color: $urgent;
}

.mullvad.on {
  color: $green;
}
.mullvad.mid {
  color: $yellow;
}
.mullvad.off {
  color: $urgent;
}
// Inner button padding (2px margin + 6px pad = 8px) replaces .mod's 13px,
// so shrink the widget's own padding to keep the bar visually even.
.mullvad {
  padding: 0px 5px;
}
.mv-icn,
.mv-relay {
  border-radius: 3px;
  margin: 2px;
}
.mv-icn {
  padding: 0px 6px;
}
.mv-relay {
  padding-left: 6px;
}
.mv-icn:hover,
.mv-relay:hover {
  background-color: $hover;
}

.i3 {
  padding: 1px;
}
.ws {
  padding: 1px 7px;
  color: $muted;
  border: 1px solid transparent;
  border-radius: 3px;
  transition: color 150ms, border-color 150ms;
}
.ws.focused {
  color: $accent;
  border-color: $accent;
}
.ws.urgent {
  color: $urgent;
  border-color: $urgent;
}
.ws:hover {
  color: $fg;
}
.ws:not(.focused):hover {
  background-color: $hover;
}
