#!/usr/bin/env bash
# Battery as JSON: { present, status, low, pct, time }. `low` (below 30% or
# under an hour left) drives the auto-reveal; `time` is "(H:MM)". The yuck
# layer maps pct/status -> glyph + colour class. Absent battery still emits
# every key the widget reads so it never hits a missing key while :visible is
# false.
absent='{"present":false,"status":"","low":false,"pct":0,"time":""}'
b=$(ls /sys/class/power_supply/ 2>/dev/null | grep -m1 '^BAT')
[ -z "$b" ] && { printf '%s' "$absent"; exit; }
d="/sys/class/power_supply/$b"

cap=$(cat "$d/capacity")
status=$(cat "$d/status")
now=$(cat "$d/energy_now" 2>/dev/null || cat "$d/charge_now" 2>/dev/null)
rate=$(cat "$d/power_now" 2>/dev/null || cat "$d/current_now" 2>/dev/null)
full=$(cat "$d/energy_full" 2>/dev/null || cat "$d/charge_full" 2>/dev/null)

secs=0
t=""
if [ -n "$rate" ] && [ "$rate" -gt 0 ]; then
	case "$status" in
	Discharging) secs=$((now * 3600 / rate)) ;;
	Charging) secs=$(((full - now) * 3600 / rate)) ;;
	esac
	[ "$secs" -gt 0 ] && t=$(printf '(%d:%02d)' $((secs / 3600)) $(((secs % 3600) / 60)))
fi

low=false
[ "$cap" -lt 30 ] && low=true
[ "$status" = Discharging ] && [ "$secs" -gt 0 ] && [ "$secs" -lt 3600 ] && low=true

printf '{"present":true,"status":"%s","low":%s,"pct":%s,"time":"%s"}' "$status" "$low" "$cap" "$t"
