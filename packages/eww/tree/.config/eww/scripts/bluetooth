#!/usr/bin/env bash
# Bluetooth as JSON: { on, names }. `on` is true when a device is connected;
# `names` is the comma-joined connected device names. Every branch emits both
# fields so the yuck widget never reads a missing key while :visible is false.
command -v bluetoothctl >/dev/null || { printf '{"on":false,"names":""}'; exit; }

names=""
for mac in $(bluetoothctl devices 2>/dev/null | awk '/^Device/ {print $2}'); do
	info=$(bluetoothctl info "$mac" 2>/dev/null)
	echo "$info" | grep -q 'Connected: yes' || continue
	n=$(printf '%s' "$info" | sed -n 's/^[[:space:]]*Name: //p' | head -1)
	names="${names:+$names, }$n"
done

if [ -z "$names" ]; then
	printf '{"on":false,"names":""}'
else
	names=$(printf '%s' "$names" | sed 's/\\/\\\\/g; s/"/\\"/g')
	printf '{"on":true,"names":"%s"}' "$names"
fi
