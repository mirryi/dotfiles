#!/usr/bin/env bash
# Backlight via sysfs (intel_backlight); `get` prints -1 to self-hide when
# absent. Writing brightness needs the `video` group or a udev rule.
bl=/sys/class/backlight/intel_backlight
[ -d "$bl" ] || { [ "$1" = get ] && echo -1; exit 0; }
max=$(cat "$bl/max_brightness")
pct() { awk -v c="$(cat "$bl/brightness")" -v m="$max" 'BEGIN {printf "%d", c * 100 / m}'; }
case "$1" in
get) pct ;;
up | down)
	# Accumulate scroll events; apply 1% every 3rd notch (3x less sensitive).
	f="${XDG_RUNTIME_DIR:-/tmp}/eww-bri-scroll"
	acc=$(cat "$f" 2>/dev/null || echo 0)
	[ "$1" = up ] && acc=$((acc + 1)) || acc=$((acc - 1))
	if [ "$acc" -ge 3 ]; then dir=up
	elif [ "$acc" -le -3 ]; then dir=down
	else echo "$acc" >"$f"; exit 0; fi
	echo 0 >"$f"

	v=$(pct)
	[ "$dir" = up ] && v=$((v + 1)) || v=$((v - 1))
	[ "$v" -gt 100 ] && v=100
	[ "$v" -lt 1 ] && v=1
	echo $((v * max / 100)) >"$bl/brightness" 2>/dev/null
	# Reveal while scrolling; hide 1.2s after the last notch.
	eww update brightness="$v" bri_show=true
	pidf="${XDG_RUNTIME_DIR:-/tmp}/eww-bri-timer"
	[ -f "$pidf" ] && kill "$(cat "$pidf")" 2>/dev/null
	(sleep 1.2 && eww update bri_show=false) >/dev/null 2>&1 &
	echo $! >"$pidf"
	;;
esac
