#!/usr/bin/env bash
# Mullvad as JSON: { state, relay }. state is connecting | connected |
# disconnected; relay is the relay id (empty unless connected). The yuck layer
# maps state -> glyph + colour class and reveals relay on hover.
out=$(mullvad status 2>/dev/null)
case "$out" in
*Connecting*) state=connecting ;;
*Connected*)  state=connected ;;
*)            state=disconnected ;;
esac
relay=$(printf '%s' "$out" | sed -n 's/.*Relay:[[:space:]]*//p' | head -1 | sed 's/[[:space:]]*$//')
printf '{"state":"%s","relay":"%s"}' "$state" "$relay"
