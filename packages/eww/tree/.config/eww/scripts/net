#!/usr/bin/env bash
# Wifi as JSON: { ssid, sig }. sig is signal 0-100 from /proc/net/wireless, or
# -1 when disconnected; SSID comes from iwd (iwctl). The yuck layer maps sig ->
# glyph.
dev=$(iwctl device list | sed 's/\x1b\[[0-9;]*m//g' | awk '/station/ {print $1; exit}')
ssid=""
[ -n "$dev" ] && ssid=$(iwctl station "$dev" show |
	sed 's/\x1b\[[0-9;]*m//g' |
	sed -n 's/.*Connected network[[:space:]]*//p' | sed 's/[[:space:]]*$//')

if [ -z "$ssid" ]; then
	printf '{"ssid":"disconnected","sig":-1}'
	exit
fi

qual=$(awk 'NR==3 {print int($3)}' /proc/net/wireless 2>/dev/null)
sig=$(((${qual:-0} * 100) / 70))
[ "$sig" -gt 100 ] && sig=100

ssid=$(printf '%s' "$ssid" | sed 's/\\/\\\\/g; s/"/\\"/g')
printf '{"ssid":"%s","sig":%s}' "$ssid" "$sig"
