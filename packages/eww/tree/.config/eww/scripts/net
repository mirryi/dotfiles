#!/usr/bin/env bash
# Wifi as JSON: { icon, ssid }. Icon is a signal ramp from /proc/net/wireless;
# SSID comes from iwd (iwctl).
dev=$(iwctl device list | sed 's/\x1b\[[0-9;]*m//g' | awk '/station/ {print $1; exit}')
ssid=""
[ -n "$dev" ] && ssid=$(iwctl station "$dev" show |
	sed 's/\x1b\[[0-9;]*m//g' |
	sed -n 's/.*Connected network[[:space:]]*//p' | sed 's/[[:space:]]*$//')

if [ -z "$ssid" ]; then
	printf '{"icon":"ůį§ģ","ssid":"disconnected"}'
	exit
fi

qual=$(awk 'NR==3 {print int($3)}' /proc/net/wireless 2>/dev/null)
sig=$(((${qual:-0} * 100) / 70))
[ "$sig" -gt 100 ] && sig=100
if [ "$sig" -ge 80 ]; then icon="ůį§®"
elif [ "$sig" -ge 60 ]; then icon="ůį§•"
elif [ "$sig" -ge 40 ]; then icon="ůį§Ę"
else icon="ůį§ü"; fi

ssid=$(printf '%s' "$ssid" | sed 's/\\/\\\\/g; s/"/\\"/g')
printf '{"icon":"%s","ssid":"%s"}' "$icon" "$ssid"
