#!/usr/bin/env bash
# pulseaudio volume (0-100).
source "$(dirname "$0")/lib"
sink=@DEFAULT_SINK@
cur() { pactl get-sink-volume "$sink" | awk 'NR==1 {print $5 + 0}'; }
case "$1" in
up | down)
	dir=$(scroll_dir vol "$1"); [ -z "$dir" ] && exit 0
	v=$(cur); v=${v:-0}
	[ "$dir" = up ] && v=$((v + 1)) || v=$((v - 1))
	[ "$v" -gt 100 ] && v=100
	[ "$v" -lt 0 ] && v=0
	pactl set-sink-volume "$sink" "${v}%"
	m=false; pactl get-sink-mute "$sink" | grep -q yes && m=true
	eww update volume="{\"vol\":$v,\"muted\":$m}"
	osd_reveal aud_show aud
	;;
mute) pactl set-sink-mute "$sink" toggle ;;
get) if pactl get-sink-mute "$sink" | grep -q yes; then echo muted; else cur; fi ;;
listen)
	# Stream {vol,muted} and flash the OSD on any change, from any source.
	state() {
		local m=false v
		pactl get-sink-mute "$sink" | grep -q yes && m=true
		v=$(cur); v=${v:-0}
		echo "{\"vol\":$v,\"muted\":$m}"
	}
	last=$(state); echo "$last"
	pactl subscribe 2>/dev/null | grep --line-buffered -E "on sink #" | while read -r _; do
		v=$(state); [ "$v" = "$last" ] && continue
		last=$v; echo "$v"; osd_reveal aud_show aud
	done
	;;
active)
	# Stream whether any output stream is playing (non-corked sink-input).
	playing() { pactl list sink-inputs 2>/dev/null | grep -q "Corked: no" && echo true || echo false; }
	last=$(playing); echo "$last"
	pactl subscribe 2>/dev/null | grep --line-buffered -E "on sink-input #" | while read -r _; do
		v=$(playing); [ "$v" = "$last" ] && continue
		last=$v; echo "$v"
	done
	;;
esac
