#!/bin/sh

# Use eza if it's found
if [ "$(command -v eza)" ]; then
	alias ls="eza -G --color auto -as type"
	alias la="eza -l --color auto -as type --git"
	alias lt="eza --tree --level=2 --color auto -as type --git"
	alias ltl="lt --long"
else
	alias ls="ls -a --color"
	alias la="ls -al --color"
fi
