// WARNING: Do not edit this file.
// It was generated by processing a template.

theme "{{ theme }}"
default_layout "default"
on_force_close "quit"
mouse_mode true
scroll_buffer_size 10000
copy_clipboard "system"
session_serialization false
styled_underlines true
pane_frames true

// tmux-style thin separators: square corners, no per-pane session name.
// zellij has no shared single-line borders like tmux; framed panes are the
// only separation mechanism, so this is as close as it gets.
ui {
    pane_frames {
        rounded_corners false
        hide_session_name true
    }
}

keybinds clear-defaults=true {
    normal {
        bind "Ctrl a" { SwitchToMode "Tmux"; }
        bind "Ctrl g" { SwitchToMode "Locked"; }
    }

    tmux {
        // splits
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }

        // pane navigation
        bind "h" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "j" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "l" { MoveFocus "Right"; SwitchToMode "Normal"; }

        // pane swap
        bind ">" { MovePane; SwitchToMode "Normal"; }
        bind "<" { MovePaneBackwards; SwitchToMode "Normal"; }

        // pane resize (repeatable via re-entering tmux mode)
        bind "H" { Resize "Left"; SwitchToMode "Normal"; }
        bind "J" { Resize "Down"; SwitchToMode "Normal"; }
        bind "K" { Resize "Up"; SwitchToMode "Normal"; }
        bind "L" { Resize "Right"; SwitchToMode "Normal"; }

        // tab navigation
        bind "Ctrl l" { GoToNextTab; SwitchToMode "Normal"; }
        bind "Ctrl h" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "c" { NewTab; SwitchToMode "Normal"; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }

        // misc
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "f" { ToggleFloatingPanes; SwitchToMode "Normal"; }
        bind "[" { SwitchToMode "Scroll"; }
        bind "d" { Detach; }
        bind "F" { SwitchToMode "Session"; }

        // plugins
        // ponytail: zj-leap had no releases; using zellij-jump-list (vim-style jump history)
        bind "r" {
            LaunchOrFocusPlugin "https://github.com/blank2121/zellij-jump-list/releases/latest/download/zellij-jump-list.wasm" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal";
        }
        bind "Ctrl f" {
            LaunchOrFocusPlugin "https://github.com/codingfragments/zellij-zextract/releases/latest/download/zextract.wasm" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal";
        }

        bind "Esc" { SwitchToMode "Normal"; }
        bind "Ctrl a" { SwitchToMode "Normal"; }
    }

    scroll {
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "f" "PageDown" { PageScrollDown; }
        bind "b" "PageUp" { PageScrollUp; }
        bind "g" { ScrollToTop; }
        bind "G" { ScrollToBottom; }
        bind "/" { SwitchToMode "EnterSearch"; }
        bind "q" "Esc" "Ctrl c" { SwitchToMode "Normal"; }
    }

    entersearch {
        bind "Enter" { SwitchToMode "Search"; }
        bind "Esc" "Ctrl c" { SwitchToMode "Scroll"; }
    }

    search {
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "n" { Search "down"; }
        bind "N" { Search "up"; }
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "w" { SearchToggleOption "Wrap"; }
        bind "q" "Esc" "Ctrl c" { SwitchToMode "Normal"; }
    }

    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }

    session {
        bind "Ctrl a" "Esc" { SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "w" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal";
        }
    }
}
