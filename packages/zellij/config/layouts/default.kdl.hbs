// It was generated by processing a template.

layout {
    default_tab_template {
        children

        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "{mode}#[fg={{ fg }},bg={{ bg1 }},bold] {session} "
                format_center "{tabs}"
                format_right  "{command_git_branch}{datetime}"
                format_space  "#[bg={{ bg1 }}]"

                border_enabled  "false"
                // ponytail: was "true", but on zellij 0.44.3 zjstatus's frame
                // auto-hide issues a toggle action that fails to route and spins
                // into an infinite loop (logs the client out -> terminal relaunches
                // -> new shell, repeat). Keep frames always-on instead.
                hide_frame_for_single_pane "false"

                mode_normal        "#[bg={{ blue }},fg={{ bg }},bold] NORMAL #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_tmux          "#[bg={{ yellow }},fg={{ bg }},bold] TMUX #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_locked        "#[bg={{ red }},fg={{ bg }},bold] LOCKED #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_pane          "#[bg={{ green }},fg={{ bg }},bold] PANE #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_tab           "#[bg={{ cyan }},fg={{ bg }},bold] TAB #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_scroll        "#[bg={{ magenta }},fg={{ bg }},bold] SCROLL #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_session       "#[bg={{ blue }},fg={{ bg }},bold] SESSION #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_resize        "#[bg={{ yellow }},fg={{ bg }},bold] RESIZE #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_move          "#[bg={{ yellow }},fg={{ bg }},bold] MOVE #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_search        "#[bg={{ magenta }},fg={{ bg }},bold] SEARCH #[bg={{ bg1 }},fg={{ bg1 }}]"
                mode_entersearch   "#[bg={{ magenta }},fg={{ bg }},bold] / #[bg={{ bg1 }},fg={{ bg1 }}]"

                tab_normal   "#[fg={{ fg4 }},bg={{ bg1 }}] {name} "
                tab_active   "#[fg={{ fg }},bg={{ bg1 }},bold] {name} "

                command_git_branch_command     "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format      "#[fg={{ blue }},bg={{ bg1 }}]  {stdout} "
                command_git_branch_interval    "10"
                command_git_branch_rendermode  "static"

                datetime        "#[fg={{ fg4 }},bg={{ bg1 }}] {format} "
                datetime_format "%H:%M"
            }
        }
    }

    tab {
        pane command="$SHELL" close_on_exit=true
    }
}
